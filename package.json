{
  "name": "prompt-manager",
  "version": "1.0.0",
  "description": "Windows desktop app for building AI prompts from instructions, backend/web code, and Android code.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis portable"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.promptmanager.desktop",
    "productName": "Prompt Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "browser-extension/**/*",
      "renderer/**/*",
      "readme"
    ],
    "asar": true,
    "asarUnpack": [
      "browser-extension/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Prompt Manager"
    }
  }
}
