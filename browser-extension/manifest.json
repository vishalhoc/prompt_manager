{
  "manifest_version": 3,
  "name": "Prompt Manager Browser Companion",
  "version": "1.0.0",
  "description": "Capture prompts from Gemini or AI Studio and paste saved Prompt Manager prompts back into the page.",
  "permissions": [
    "activeTab",
    "notifications",
    "offscreen",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://gemini.google.com/*",
    "https://aistudio.google.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*"
  ],
  "action": {
    "default_title": "Prompt Manager",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
